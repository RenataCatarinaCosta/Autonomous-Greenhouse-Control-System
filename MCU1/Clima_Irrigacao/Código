void enviarLoRaTudo() {                                          //Assegura com 80 ms que não há conflito de envio de pacotes 
  enviarLoRaClima();
  delay(80);
  enviarLoRaIrriga();
}

// SETPOINTS
void atualizarSetpointsClima(String cmd) {                       //Verifica o pacote
  int p1 = cmd.indexOf(':');
  int p2 = cmd.indexOf(',', p1 + 1);
  int p3 = cmd.indexOf(',', p2 + 1);
  int p4 = cmd.indexOf(',', p3 + 1);

  if (p1 > 0 && p2 > p1 && p3 > p2 && p4 > p3) {                  //Verifica estrutura do pacote
    float novoTempOn = cmd.substring(p1 + 1, p2).toFloat();       //Extrai a informação para cada variavel
    float novoTempOff = cmd.substring(p2 + 1, p3).toFloat();
    float novaHumMin = cmd.substring(p3 + 1, p4).toFloat();
    float novaHumMax = cmd.substring(p4 + 1).toFloat();

    if (novoTempOn > novoTempOff && novaHumMin < novaHumMax &&
        novaHumMin >= 0 && novaHumMax <= 100) {

      TEMP_LIGAR = novoTempOn;
      TEMP_DESLIGAR = novoTempOff;
      HUMR_MIN = novaHumMin;
      HUMR_MAX = novaHumMax;

      Serial.println("Setpoints CLIMA atualizados");
      atualizarBuzzer();
      precisaAtualizarEcra = true;
      enviarLoRaClima();
    } else {
      Serial.println("ERRO setpoints CLIMA invalidos");
    }
  }
}

void atualizarSetpointsIrriga(String cmd) {
  int p1 = cmd.indexOf(':');                                                           //Guarda a posição dos :
  int p2 = cmd.indexOf(',');                                                            //Guarda a posição da  , 

  if (p1 > 0 && p2 > p1) {
    int novoLigar = cmd.substring(p1 + 1, p2).toInt();                                 // Extrai unicamente os valores, daí o +1, para garantir que não inclui : ou ,
    int novoDesligar = cmd.substring(p2 + 1).toInt();

    if (novoLigar >= 0 && novoDesligar <= 100 && novoLigar < novoDesligar) {          //Verifica os Valores Extraídos
      HUM_SOLO_LIGAR = novoLigar;
      HUM_SOLO_DESLIGAR = novoDesligar;

      Serial.println("Setpoints IRRIGA atualizados");
      atualizarBuzzer();
      precisaAtualizarEcra = true;
      enviarLoRaIrriga();
    } else {
      Serial.println("ERRO setpoints IRRIGA invalidos");
    }
  }
}

// PROCESSAMENTO DOS COMANDOS
void processarComando(String cmd) {
  cmd.trim();                                                          //Assegura a eleminação de lixo
  Serial.print("Comando recebido no ESP1: [");
  Serial.print(cmd);
  Serial.println("]");

  if (cmd == "FAN_ON") {
    modoManualClima = true;
    ligarFan();
  }

  else if (cmd == "FAN_OFF") {
    modoManualClima = true;
    desligarFan();
  }

  else if (cmd == "BOMBA_ON") {
    modoManualIrriga = true;
    ligarBomba();
  }

  else if (cmd == "BOMBA_OFF") {
    modoManualIrriga = true;
    desligarBomba();
  }

  else if (cmd == "MODO_AUTO_CLIMA") {
    modoManualClima = false;
    Serial.println("CLIMA AUTO");
    enviarLoRaClima();
  }

  else if (cmd == "MODO_AUTO_IRRIGA") {
    modoManualIrriga = false;
    Serial.println("IRRIGA AUTO");
    enviarLoRaIrriga();
  }

  else if (cmd == "MODO_AUTO") {                               //se o botão antigo ainda mandar MODO_AUTO, mete ambos em auto
    modoManualClima = false;
    modoManualIrriga = false;
    Serial.println("CLIMA + IRRIGA AUTO");
    enviarLoRaTudo();
  }

  else if (cmd.startsWith("SET_TEMP:")) {                     //Verifica qual sistema está a receber informação nova e manda-o atualizar
    atualizarSetpointsClima(cmd);
  }

  else if (cmd.startsWith("SET_SOIL:")) {
    atualizarSetpointsIrriga(cmd);
  }

  else if (cmd == "REQUEST_DATA") {
    lerClima();
    lerIrriga();
    enviarLoRaTudo();
  }

  else {
    Serial.println("Comando desconhecido no ESP1");
  }
}

