// THINGSPEAK E SUA ATUALIZAÇÃO
void enviarThingSpeakClima() {
  if (!bmeOK) return;
  if (WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;                                                  //Cria um objeto HTTP
  String url = server + "?api_key=" + apiKeyClima;                   //Identifica o canal
  url += "&field1=" + String(temperatura);                           //Identiifica os campos
  url += "&field2=" + String(pressao);
  url += "&field3=" + String(humidadeR);
  url += "&field4=" + String(fanAtiva ? 1 : 0);
  url += "&field5=" + String(modoManualClima ? 1 : 0);
  url += "&field6=" + String(TEMP_LIGAR, 1);
  url += "&field7=" + String(TEMP_DESLIGAR, 1);
  url += "&field8=" + String(vpd, 2);

  http.begin(url);
  http.setTimeout(800);
  int httpCode = http.GET();                                          //Os dados irão no próprio link
  http.end();

  Serial.print("ThingSpeak CLIMA HTTP = ");
  Serial.println(httpCode);                                           //se aparecer 200 significa envio com sucesso
}

