void verificarThingSpeakClima(unsigned long agora) {
  bool mudou =                                                            //Verifica se :
    abs(temperatura - ultimaTempSheet) >= 0.2 ||                          //Temperatura variou mais de 0.2 graus celsius
    abs(pressao - ultimaPressSheet) >= 20 ||                              //Pressão variou mais de 20 Pa
    abs(humidadeR - ultimaHumRSheet) >= 1 ||                              // Humidade relativa variou mais de 1%
    abs(vpd - ultimoVPDSheet) >= 0.05 ||                                  //VPD variou mais de 0.05 KPa
    fanAtiva != ultimaFanSheet ||                                         //E se os estados dos atuadores e setpoints alteraram
    modoManualClima != ultimoModoClimaSheet ||
    TEMP_LIGAR != ultimoTempLigarSheet ||
    TEMP_DESLIGAR != ultimoTempDesligarSheet ||
    primeiroEnvioClima;

  if (agora - ultimoEnvioSheetClima >= INTERVALO_SHEET && mudou) {        //Verifica se já passou o tempo mínimo de envio desde o último envio ou se algo mudou e depois decide se envia dados 
    ultimoEnvioSheetClima = agora;
    enviarThingSpeakClima();

    ultimaTempSheet = temperatura;                                        //Atualiza os registos dos valores e estados das variáveis
    ultimaPressSheet = pressao;
    ultimaHumRSheet = humidadeR;
    ultimoVPDSheet = vpd;
    ultimaFanSheet = fanAtiva;
    ultimoModoClimaSheet = modoManualClima;
    ultimoTempLigarSheet = TEMP_LIGAR;
    ultimoTempDesligarSheet = TEMP_DESLIGAR;
    primeiroEnvioClima = false;                                            
  }
}

void verificarThingSpeakIrriga(unsigned long agora) {
  bool mudou =                                                            //Verifica se :
    abs(humidadeSolo - ultimaHumSoloSheet) >= 1 ||                        //Humidade do solo variou mais de 1%
    abs(valorBrutoSolo - ultimoBrutoSoloSheet) >= 10 ||                   // Valor bruto da humidade variou mais de 10 unidades
    bombaAtiva != ultimaBombaSheet ||                                     //E se os estados dos atuadores e setpoints alteraram
    modoManualIrriga != ultimoModoIrrigaSheet ||
    HUM_SOLO_LIGAR != ultimoHumSoloLigarSheet ||
    HUM_SOLO_DESLIGAR != ultimoHumSoloDesligarSheet ||
    primeiroEnvioIrriga;

  if (agora - ultimoEnvioSheetIrriga >= INTERVALO_SHEET && mudou) {
    ultimoEnvioSheetIrriga = agora;
    enviarThingSpeakIrriga();

    ultimaHumSoloSheet = humidadeSolo;
    ultimoBrutoSoloSheet = valorBrutoSolo;
    ultimaBombaSheet = bombaAtiva;
    ultimoModoIrrigaSheet = modoManualIrriga;
    ultimoHumSoloLigarSheet = HUM_SOLO_LIGAR;
    ultimoHumSoloDesligarSheet = HUM_SOLO_DESLIGAR;
    primeiroEnvioIrriga = false;
  }
}

// COMUNICAÇÃO LORA
void enviarLoRaClima() {                                          //Pacote enviado para o ESP2 contém valores e estados booleanos de forma a simplificar o pacote de envio
  if (!loraOK) {
  Serial.println("LoRa indisponivel - pacote CLIMA nao enviado");
  return;
}
  String pacote = "CLIMA:";
  pacote += String(temperatura) + ",";
  pacote += String(pressao) + ",";
  pacote += String(humidadeR) + ",";
  pacote += String(fanAtiva ? 1 : 0) + ",";                       //Estados booleanos
  pacote += String(modoManualClima ? 1 : 0) + ",";
  pacote += String(TEMP_LIGAR, 1) + ",";                          //Defenição de casas decimais
  pacote += String(TEMP_DESLIGAR, 1) + ",";                
  pacote += String(HUMR_MIN, 0) + ",";                            
  pacote += String(HUMR_MAX, 0) + ",";
  pacote += String(vpd, 2) + ",";
  pacote += String(bmeOK ? 1 : 0);

  LoRa.beginPacket();
  LoRa.print(pacote);
  LoRa.endPacket();

  Serial.print("LoRa CLIMA enviado: ");
  Serial.println(pacote);
}

void enviarLoRaIrriga() {                                       //Segue a mesma lógica do clima
  if (!loraOK) {
  Serial.println("LoRa indisponivel - pacote IRRIGA nao enviado");
  return;
}
  String pacote = "IRRIGA:";
  pacote += String(humidadeSolo) + ",";
