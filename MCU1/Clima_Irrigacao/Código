  u8g2.drawStr(0, 42, linha);

  sprintf(linha, "SetT:%.1f/%.1f", TEMP_LIGAR, TEMP_DESLIGAR);
  u8g2.drawStr(0, 52, linha);

  u8g2.drawStr(0, 62, estadoClima().c_str());
  u8g2.sendBuffer();
}

void pageNaoAtivo(const char* titulo) {
  u8g2.clearBuffer();
  u8g2.setDrawColor(1);
  u8g2.setFont(u8g2_font_6x10_tr);
  u8g2.drawStr(25, 10, titulo);
  u8g2.setFont(u8g2_font_5x7_tr);
  u8g2.drawStr(0, 28, "Modulo nao ativo");
  u8g2.drawStr(0, 45, "OK: voltar");
  u8g2.sendBuffer();
}

void atualizarDisplay() {
  switch (pagina) {
    case 0: drawMenu(); break;
    case 1: pageIrrigacao(); break;
    case 2: pageNaoAtivo("ILUMINACAO"); break;
    case 3: pageClima(); break;
    case 4: pageNaoAtivo("CO2"); break;
    case 5: pageNaoAtivo("PH"); break;
    case 6: pageNaoAtivo("ENERGIA"); break;
  }
}





// SETUP
void setup() {
  Serial.begin(115200);                                                      //Baud rate utilizada, rápida e estável
  delay(1000);

  pinMode(FAN_PIN, OUTPUT);
  digitalWrite(FAN_PIN, LOW);                                               //Garante que atuador começa OFF

  pinMode(BOMBA_PIN, OUTPUT);
  digitalWrite(BOMBA_PIN, LOW);

  pinMode(BTN_NAV, INPUT_PULLUP);
  pinMode(BTN_OK, INPUT_PULLUP);

  analogReadResolution(12);
  analogSetAttenuation(ADC_11db);

  ledcAttach(BUZZER_PIN, BUZZER_FREQ, BUZZER_RES);                         //PWM
  ledcWrite(BUZZER_PIN, 0);                                                //Inicia desligado

  Wire.begin(21, 22);
  Wire.setClock(50000);                                                    //Velocidade de 50KHz para tentar evitar instabilidade no barramento I2C

  u8g2.setBusClock(400000);                                               //Velocidade de 400 KHz
  u8g2.begin();
  atualizarDisplay();

  if (BME280.begin(0x76)) {
  bmeOK = true;
  Serial.println("BME280 OK em 0x76");
}
else if (BME280.begin(0x77)) {
  bmeOK = true;
  Serial.println("BME280 OK em 0x77");
}
else {
  bmeOK = false;
  Serial.println("BME280 nao encontrado - sistema continua sem clima");
}

  WiFi.begin(ssid, password);                                             //Inicia a ligação WIFI

  int tentativas = 0;
  while (WiFi.status() != WL_CONNECTED && tentativas < 20) {
    delay(500);
    Serial.print(".");
    tentativas++;
  }

  Serial.println();
  Serial.println(WiFi.status() == WL_CONNECTED ? "WiFi OK" : "WiFi falhou");

  SPI.begin(5, 19, 27, 18);                                                //Comunicação SPI
  LoRa.setPins(LORA_SS, LORA_RST, LORA_DIO0);                              //Inicia os pinos LoRa

  if (!LoRa.begin(868E6)) {
    loraOK = true;
    Serial.println("LoRa OK");
  }else{
    loraOK = false;
    Serial.printlln("LoRa falhou - Controlo Local continua sem LoRa")
  }


  lerClima();
  lerIrriga();
  enviarLoRaTudo();
  precisaAtualizarEcra = true;
}

// LOOP
void loop() {
  unsigned long agora = millis();                                          //Contagem de tempo desde que o programa inicia

  bool nav = digitalRead(BTN_NAV);                                         //Lê o estado dos botões
  bool ok = digitalRead(BTN_OK);
  if (ok == LOW && lastOk == HIGH && (agora - ultimoBtnOk > DEBOUNCE_MS)) {   //Verifica estado anterior do botão e tempo mínimo de leitura
    ultimoBtnOk = agora;
    if (pagina == 0) {                                                         // se está na página do menu entra na página selecionada, se está dentro de uma página, volta ao menu
      pagina = menuIndex + 1;
    } else {
      pagina = 0;

    }
    precisaAtualizarEcra = true;
  }

  if (nav == LOW && lastNav == HIGH && (agora - ultimoBtnNav > DEBOUNCE_MS)) {   
    ultimoBtnNav = agora;                                                         
    if (pagina == 0) {                                                            //se estiver no menu passa para a próxima opção
      menuIndex++;
      if (menuIndex >= MENU_SIZE) menuIndex = 0;
      precisaAtualizarEcra = true;
    }
  }
  lastNav = nav;
  lastOk = ok;


  if (Serial.available()) {                                                     //Verifica se algum comando foi enviado  diretamente através do serial monitor e processa-o
    String cmd = Serial.readString();
    cmd.trim();
    if (cmd.length() > 0) {
      processarComando(cmd);
    }
  }


  if (loraOK) {
  int packetSize = LoRa.parsePacket();                                         //Verifica se algum pacote chegou por LoRa

  if (packetSize) {
    String cmd = "";
    while (LoRa.available()) {
      cmd += (char)LoRa.read();
    }
    Serial.print("LORA RECEBIDO NO ESP1 = [");
    Serial.print(cmd);
    Serial.println("]");
    processarComando(cmd);
  }
}

  if (agora - ultimaLeituraClima >= INTERVALO_CLIMA) {
    ultimaLeituraClima = agora;
    lerClima();
  }
  if (agora - ultimaLeituraIrriga >= INTERVALO_IRRIGA) {
    ultimaLeituraIrriga = agora;
    lerIrriga();
  }


  if (agora - ultimoEnvioLoRa >= INTERVALO_LORA) {                            //Envio de dados por LoRa
    ultimoEnvioLoRa = agora;
    enviarLoRaTudo();
  }


  verificarThingSpeakClima(agora);                                          //Verifica se deve enviar dados para a base de dados
  verificarThingSpeakIrriga(agora);


  if (!modoManualClima) {
  if (bmeOK) {
    if (!fanAtiva && temperatura > TEMP_LIGAR) {
      ligarFan();
    }
    if (fanAtiva && temperatura < TEMP_DESLIGAR) {
      desligarFan();
    }
  } else {
    if (fanAtiva) desligarFan();
  }
}

if (!modoManualIrriga) {
  if (!sensorSoloErro()) {
    if (!bombaAtiva && humidadeSolo < HUM_SOLO_LIGAR) {
      ligarBomba();
    }
    if (bombaAtiva && humidadeSolo > HUM_SOLO_DESLIGAR) {
      desligarBomba();
    }
  } else {
    if (bombaAtiva) desligarBomba();
  }
}

  atualizarBuzzer();

  if (agora - ultimoRefreshDisplay >= REFRESH_DISPLAY) {
    ultimoRefreshDisplay = agora;
    precisaAtualizarEcra = true;
  }
  if (precisaAtualizarEcra) {
    atualizarDisplay();
    precisaAtualizarEcra = false;
  }
  delay(10);
}

