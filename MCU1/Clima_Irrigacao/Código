// BUZZER
void ligarBuzzer() {
  if (!buzzerAtivo) {
    ledcWrite(BUZZER_PIN, 128);                                              //Ligar buzzer a 50% da capacidade total, 0-255
    buzzerAtivo = true;
    Serial.println("BUZZER ON");
  }
} 

void desligarBuzzer() {
  if (buzzerAtivo) {
    ledcWrite(BUZZER_PIN, 0);
    buzzerAtivo = false;
    Serial.println("BUZZER OFF");
  }
}

void atualizarBuzzer() {
  bool alarmeClima = (estadoClima() != "CLIMA OK");
  bool alarmeIrriga = (estadoIrriga() != "SOLO OK");

  if (alarmeClima || alarmeIrriga) {
    ligarBuzzer();
  } else {
    desligarBuzzer();
  }
}

// LEITURAS   DOS SENSORES
void lerClima() {
 if (!bmeOK) {
    Serial.println("BME280 indisponivel - leitura de clima ignorada");
    precisaAtualizarEcra = true;
    atualizarBuzzer();
    return;
  }

  float novaTemp = BME280.readTemperature();
  float novaPressao = BME280.readPressure();
  float novaHumR = BME280.readHumidity();

  if (isnan(novaTemp) || isnan(novaPressao) || isnan(novaHumR)) {
    bmeOK = false;
    Serial.println("Erro de leitura BME280 - clima desativado");
    precisaAtualizarEcra = true;
    atualizarBuzzer();
    return;
  }

  temperatura = novaTemp;
  pressao = novaPressao;
  humidadeR = novaHumR;
  vpd = calcularVPD(temperatura, humidadeR);


  Serial.print("CLIMA -> T=");
  Serial.print(temperatura);
  Serial.print(" HR=");
  Serial.print(humidadeR);
  Serial.print(" P=");
  Serial.print(pressao);
  Serial.print(" VPD=");
  Serial.print(vpd);
  Serial.print(" Estado=");
  Serial.println(estadoClima());

  atualizarBuzzer();
  precisaAtualizarEcra = true;
}

void lerIrriga() {
  long soma = 0;

  for (int i = 0; i < 20; i++) {                                              //Realiza uma média de forma a reduzir as flutuações de valores
    soma += analogRead(SOIL_PIN);
    delay(5);
  }

  valorBrutoSolo = soma / 20;

  humidadeSolo = map(valorBrutoSolo, VALOR_SECO, VALOR_MOLHADO, 0, 100);
  humidadeSolo = constrain(humidadeSolo, 0, 100);                            //Garante que valor está entre 0% e 100%

  Serial.print("IRRIGA -> Hum=");
  Serial.print(humidadeSolo);
  Serial.print("% Bruto=");
  Serial.print(valorBrutoSolo);
  Serial.print(" Estado=");
  Serial.println(estadoIrriga());

  atualizarBuzzer();
  precisaAtualizarEcra = true;
}

