// FUNÇÕES AUXILIARES CLIMA
float calcularVPD(float tempC, float rh) {
  float svp = 0.6108 * exp((17.27 * tempC) / (tempC + 237.3));                //Fórmula prsente na LITERATURE REVIEW
  return svp * (1.0 - (rh / 100.0));
}

