// PROCESSAR NEXTION
void processarComandoNextion(String cmd) {
  cmd.trim();                                                                           //Assegura que não inclui lixo
  Serial.print("CMD FILTRADO = [");
  Serial.print(cmd);
  Serial.println("]");

  if (millis() - ultimoToque < DEBOUNCE_NEXTION) {                                     //Assegura o tempo mínimo entre comandos
    Serial.println("Ignorado por debounce");
    return;
  }
  ultimoToque = millis();

  // CLIMA
  if (cmd.indexOf("FAN_ON") >= 0) {
    enviarLoRa("FAN_ON");
    enviarParaNextion("tStatusClima.txt=\"FAN ON enviado\"");
  }
  else if (cmd.indexOf("FAN_OFF") >= 0) {
    enviarLoRa("FAN_OFF");
    enviarParaNextion("tStatusClima.txt=\"FAN OFF enviado\"");
  }
  else if (cmd.indexOf("MODO_AUTO_CLIMA") >= 0) {
    enviarLoRa("MODO_AUTO_CLIMA");
    enviarParaNextion("tStatusClima.txt=\"AUTO enviado\"");
  }

  // IRRIGAÇÃO
  else if (cmd.indexOf("BOMBA_ON") >= 0) {
    enviarLoRa("BOMBA_ON");
    enviarParaNextion("tStatusIrriga.txt=\"BOMBA ON enviado\"");
  }
  else if (cmd.indexOf("BOMBA_OFF") >= 0) {
    enviarLoRa("BOMBA_OFF");
    enviarParaNextion("tStatusIrriga.txt=\"BOMBA OFF enviado\"");
  }
  else if (cmd.indexOf("MODO_AUTO_IRRIGA") >= 0) {
    enviarLoRa("MODO_AUTO_IRRIGA");
    enviarParaNextion("tStatusIrriga.txt=\"AUTO enviado\"");
  }
  else if (cmd.indexOf("MODO_AUTO") >= 0) {
    enviarLoRa("MODO_AUTO");
    enviarParaNextion("tStatusClima.txt=\"AUTO enviado\"");
    enviarParaNextion("tStatusIrriga.txt=\"AUTO enviado\"");
  }

  // Setpoints
  // temperatura 
  else if (cmd.indexOf("INC_TEMP_ON") >= 0) {                                              //Processa os incrementos do display
    tempLigar += 0.5;                                                                       //Botões + e - do limite superior do inetervalo de setpoints
    if (tempLigar > 40.0) tempLigar = 40.0;
    if (tempLigar <= tempDesligar) tempLigar = tempDesligar + 0.5;                         //Assegura lógica de valores
    atualizarPaginaSetpoints();
    atualizarStatusClima();
  }

  else if (cmd.indexOf("DEC_TEMP_ON") >= 0) {                                               
    tempLigar -= 0.5;
    if (tempLigar < 5.0) tempLigar = 5.0;
    if (tempLigar <= tempDesligar) tempLigar = tempDesligar + 0.5;
    atualizarPaginaSetpoints();
    atualizarStatusClima();
  }

  else if (cmd.indexOf("INC_TEMP_OFF") >= 0) {                                              //Botões + e - do limite inferior do inetervalo de setpoints
    tempDesligar += 0.5;
    if (tempDesligar > 39.5) tempDesligar = 39.5;
    if (tempDesligar >= tempLigar) tempDesligar = tempLigar - 0.5;
    atualizarPaginaSetpoints();
    atualizarStatusClima();
  }

  else if (cmd.indexOf("DEC_TEMP_OFF") >= 0) {
    tempDesligar -= 0.5;
    if (tempDesligar < 5.0) tempDesligar = 5.0;
    atualizarPaginaSetpoints();
    atualizarStatusClima();
  }

  // Humidade relativa
  else if (cmd.indexOf("INC_HUMR_ON") >= 0) {                                             //Botões + e - do limite superior do inetervalo de setpoints
    humRMax += 5;
    if (humRMax > 100) humRMax = 100;
    atualizarPaginaSetpoints();
    atualizarStatusClima();
  }

  else if (cmd.indexOf("DEC_HUMR_ON") >= 0) {
    humRMax -= 5;
    if (humRMax < 5) humRMax = 5;
    if (humRMax <= humRMin) humRMax = humRMin + 5;
    atualizarPaginaSetpoints();
    atualizarStatusClima();
  }

  else if (cmd.indexOf("INC_HUMR_OFF") >= 0) {                                          //Botões + e - do limite Inferior do inetervalo de setpoints
    humRMin += 5;
    if (humRMin > 95) humRMin = 95;
    if (humRMin >= humRMax) humRMin = humRMax - 5;
    atualizarPaginaSetpoints();
    atualizarStatusClima();
  }

  else if (cmd.indexOf("DEC_HUMR_OFF") >= 0) {
    humRMin -= 5;
    if (humRMin < 0) humRMin = 0;
    atualizarPaginaSetpoints();
    atualizarStatusClima();
  }

  // Irrigação
  //Humidade do solo
  else if (cmd.indexOf("INC_HUM_ON") >= 0) {                                                          //Botões + e - do limite superior do inetervalo de setpoints
    humSoloDesligar += 5;
    if (humSoloDesligar > 100) humSoloDesligar = 100;
    atualizarPaginaSetpoints();
    atualizarStatusIrriga();
  }
  else if (cmd.indexOf("DEC_HUM_ON") >= 0) {
    humSoloDesligar -= 5;
    if (humSoloDesligar < 5) humSoloDesligar = 5;
    if (humSoloDesligar <= humSoloLigar) humSoloDesligar = humSoloLigar + 5;
    atualizarPaginaSetpoints();
    atualizarStatusIrriga();
  }

  else if (cmd.indexOf("INC_HUM_OFF") >= 0) {                                                       //Botões + e - do limite Inferior do inetervalo de setpoints
    humSoloLigar += 5;
    if (humSoloLigar > 95) humSoloLigar = 95;
    if (humSoloLigar >= humSoloDesligar) humSoloLigar = humSoloDesligar - 5;
    atualizarPaginaSetpoints();
    atualizarStatusIrriga();
  }
  else if (cmd.indexOf("DEC_HUM_OFF") >= 0) {
    humSoloLigar -= 5;
    if (humSoloLigar < 0) humSoloLigar = 0;
    atualizarPaginaSetpoints();
    atualizarStatusIrriga();
  }

  // Botão GUARDAR
  else if (cmd.indexOf("GUARDAR_SETPOINTS") >= 0) {                                                         //Processamento da atualização dos setpoints e do seu envio para o ESP1
    if (tempLigar > tempDesligar && humRMin < humRMax && humSoloLigar < humSoloDesligar) {
      String cmdClima = "SET_TEMP:";
      cmdClima += String(tempLigar, 1);
      cmdClima += ",";
      cmdClima += String(tempDesligar, 1);
      cmdClima += ",";
      cmdClima += String(humRMin, 0);
      cmdClima += ",";
      cmdClima += String(humRMax, 0);

      String cmdIrriga = "SET_SOIL:";
      cmdIrriga += String(humSoloLigar);
      cmdIrriga += ",";
      cmdIrriga += String(humSoloDesligar);

      Serial.print("A ENVIAR SETPOINTS CLIMA: ");
      Serial.println(cmdClima);
      enviarLoRa(cmdClima);
      delay(80);
      Serial.print("A ENVIAR SETPOINTS IRRIGA: ");
      Serial.println(cmdIrriga);
      enviarLoRa(cmdIrriga);
      enviarParaNextion("tStatusClima.txt=\"Setpoints enviados\"");
      enviarParaNextion("tStatusIrriga.txt=\"Setpoints enviados\"");
    }
  }

  else {
    Serial.print("COMANDO DESCONHECIDO: ");
    Serial.println(cmd);
  }
  atualizarBuzzer();
}

// INTERPRETA COMANDOS recebidos ENVIADOS PELO NEXTION
void lerNextion() {
  while (NextionSerial.available()) {
    char c = NextionSerial.read();                                                         //Assegura que não aceita lixo
    if ((c >= 'A' && c <= 'Z') ||
        (c >= 'a' && c <= 'z') ||
        (c >= '0' && c <= '9') ||
        c == '_') {
      bufferNextion += c;
    }
 
    if (bufferNextion.indexOf("FAN_ON") >= 0) {
      bufferNextion = ""; 
      processarComandoNextion("FAN_ON");
