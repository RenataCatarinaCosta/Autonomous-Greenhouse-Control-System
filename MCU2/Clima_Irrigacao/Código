//COMUNICAÇÃO COM O NEXTION
void enviarParaNextion(String comando) {
  NextionSerial.print(comando);
  NextionSerial.write(0xFF);
  NextionSerial.write(0xFF);
  NextionSerial.write(0xFF);
}

// ESTADOS DOS SISTEMAS- ALERTAS
String estadoClima() {
  if (ultimoRecebimentoClima == 0) return "A AGUARDAR CLIMA";
  if (millis() - ultimoRecebimentoClima > 120000) return "SINAL PERDIDO!";
  if (sensorClimaOK == 0) return "ERRO BME280";

  if (temperatura < tempDesligar) return "TEMP BAIXA";
  if (temperatura > tempLigar) return "TEMP ALTA";
  if (humidadeR < humRMin) return "HUM BAIXA";
  if (humidadeR > humRMax) return "HUM ALTA";
  if (vpd < VPD_MIN) return "VPD BAIXO";
  if (vpd > VPD_MAX) return "VPD ALTO";

  return "CLIMA OK";
}

bool sensorSoloErro() {
  return (valorBrutoSolo <= 0 || valorBrutoSolo >= 4095);
}

String estadoIrriga() {
  if (ultimoRecebimentoIrriga == 0) return "A AGUARDAR SOLO";
  if (millis() - ultimoRecebimentoIrriga > 120000) return "SINAL PERDIDO!";
  if (sensorSoloOK == 0) return "ERRO SENSOR";

  if (humidadeSolo < humSoloLigar) return "SOLO SECO";
  if (humidadeSolo > humSoloDesligar) return "SOLO MOLHADO";

  return "SOLO OK";
}

void atualizarStatusClima() {
  String estado = estadoClima();

  enviarParaNextion("tStatusClima.txt=\"" + estado + "\"");                                //Atualização do estado no display, com cores de acordo

  if (estado == "CLIMA OK") {
    enviarParaNextion("tStatusClima.pco=5653");
  } else if (estado == "A AGUARDAR CLIMA") {
    enviarParaNextion("tStatusClima.pco=65535");      
  } else {
    enviarParaNextion("tStatusClima.pco=63488");
  }
}

void atualizarStatusIrriga() {
  String estado = estadoIrriga();

  enviarParaNextion("tStatusIrriga.txt=\"" + estado + "\"");

  if (estado == "SOLO OK") {
    enviarParaNextion("tStatusIrriga.pco=5653");
  } else if (estado == "A AGUARDAR SOLO") {
    enviarParaNextion("tStatusIrriga.pco=65535");
  } else {
    enviarParaNextion("tStatusIrriga.pco=63488");
  }
}


// BUZZER
void ligarBuzzer() {                                                                         //Controlo do alerta sonoro presente o«no MCU2
  if (!buzzerAtivo) {
    ledcWrite(BUZZER_PIN, 128);
    buzzerAtivo = true;
    Serial.println("BUZZER ON");
  }
}

void desligarBuzzer() {
  if (buzzerAtivo) {
    ledcWrite(BUZZER_PIN, 0);
    buzzerAtivo = false;
    Serial.println("BUZZER OFF");
  }
}

void atualizarBuzzer() {
  bool alarmeClima = (ultimoRecebimentoClima != 0 && estadoClima() != "CLIMA OK");
  bool alarmeIrriga = (ultimoRecebimentoIrriga != 0 && estadoIrriga() != "SOLO OK");

  if (alarmeClima || alarmeIrriga) ligarBuzzer();
  else desligarBuzzer();
}


// COMUNICAÇÃO LORA
void enviarLoRa(String comando) {
  if (!loraOK) {
    Serial.print("LoRa indisponivel - comando nao enviado: ");
    Serial.println(comando);
    enviarParaNextion("tStatusClima.txt=\"LoRa indisponivel\"");
    enviarParaNextion("tStatusClima.pco=63488");
    enviarParaNextion("tStatusIrriga.txt=\"LoRa indisponivel\"");
    enviarParaNextion("tStatusIrriga.pco=63488");
    return;
  }
  Serial.print("Enviado LoRa: ");
  Serial.println(comando);
  LoRa.beginPacket();
  LoRa.print(comando);
  LoRa.endPacket();
}

