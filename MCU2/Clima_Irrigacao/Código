// PROCESSAR PACOTES RECEBIDOS POR LORA
void processarPacoteClima(String dados) {
  int p1 = dados.indexOf(',');
  int p2 = dados.indexOf(',', p1 + 1);
  int p3 = dados.indexOf(',', p2 + 1);
  int p4 = dados.indexOf(',', p3 + 1);
  int p5 = dados.indexOf(',', p4 + 1);
  int p6 = dados.indexOf(',', p5 + 1);
  int p7 = dados.indexOf(',', p6 + 1);
  int p8 = dados.indexOf(',', p7 + 1);
  int p9 = dados.indexOf(',', p8 + 1);
  int p10 = dados.indexOf(',', p9 + 1);

  if (p1 > 0 && p2 > 0 && p3 > 0 && p4 > 0 && p5 > 0 &&
      p6 > 0 && p7 > 0 && p8 > 0 && p9 > 0 && p10 > 0) {

    temperatura = dados.substring(6, p1).toFloat();                                             //Extração correta dos valores e dados dos pacotes
    pressao = dados.substring(p1 + 1, p2).toFloat();
    humidadeR = dados.substring(p2 + 1, p3).toFloat();
    fanEstado = dados.substring(p3 + 1, p4).toInt();
    modoClimaEstado = dados.substring(p4 + 1, p5).toInt();
    tempLigar = dados.substring(p5 + 1, p6).toFloat();
    tempDesligar = dados.substring(p6 + 1, p7).toFloat();
    humRMin = dados.substring(p7 + 1, p8).toFloat();
    humRMax = dados.substring(p8 + 1, p9).toFloat();
    vpd = dados.substring(p9 + 1, p10).toFloat();
    sensorClimaOK = dados.substring(p10 + 1).toInt();

    ultimoRecebimentoClima = millis();

    atualizarDisplayClima();
    atualizarPaginaSetpoints();
    atualizarBuzzer();
    Serial.print("CLIMA recebido: ");
    Serial.println(dados);
  }
}

void processarPacoteIrriga(String dados) {
  int p1 = dados.indexOf(',');
  int p2 = dados.indexOf(',', p1 + 1);
  int p3 = dados.indexOf(',', p2 + 1);
  int p4 = dados.indexOf(',', p3 + 1);
  int p5 = dados.indexOf(',', p4 + 1);
  int p6 = dados.indexOf(',', p5 + 1);

  if (p1 > 0 && p2 > 0 && p3 > 0 && p4 > 0 && p5 > 0 && p6 > 0) {
    humidadeSolo = dados.substring(7, p1).toInt();
    valorBrutoSolo = dados.substring(p1 + 1, p2).toInt();
    bombaEstado = dados.substring(p2 + 1, p3).toInt();
    modoIrrigaEstado = dados.substring(p3 + 1, p4).toInt();
    humSoloLigar = dados.substring(p4 + 1, p5).toInt();
    humSoloDesligar = dados.substring(p5 + 1, p6).toInt();
    sensorSoloOK = dados.substring(p6 + 1).toInt();
    
    ultimoRecebimentoIrriga = millis();

    atualizarDisplayIrriga();
    atualizarPaginaSetpoints();
    atualizarBuzzer();
    Serial.print("IRRIGA recebido: ");
    Serial.println(dados);
  }
}


// SETUP
void setup() {
  Serial.begin(115200);                                                           //Baud rate urilizado para a comunicação
  delay(500);

  NextionSerial.begin(9600, SERIAL_8N1, 14, 13);                                   //Baud rate utilizado no display nextion
  delay(500);

  ledcAttach(BUZZER_PIN, BUZZER_FREQ, BUZZER_RES);                                //Inicialização do alerta sonoro
  ledcWrite(BUZZER_PIN, 0);

  SPI.begin(5, 19, 27, 18);                                                       //Inicialização dos pinos da comunicação LoRa
  LoRa.setPins(LORA_SS, LORA_RST, LORA_DIO0);

 if (LoRa.begin(868E6)) {
  loraOK = true;
  Serial.println("LoRa OK");
} else {
  loraOK = false;
  Serial.println("LoRa falhou - Nextion continua ativo");
  enviarParaNextion("tStatusClima.txt=\"LoRa indisponivel\"");
  enviarParaNextion("tStatusClima.pco=63488");
  enviarParaNextion("tStatusIrriga.txt=\"LoRa indisponivel\"");
  enviarParaNextion("tStatusIrriga.pco=63488");
}

  Serial.println("LoRa OK");

  delay(300);
  enviarParaNextion("page Clima");
  delay(200);

  atualizarPaginaSetpoints();
  atualizarStatusClima();
  atualizarStatusIrriga();

  Serial.println("Nextion OK");
}



// LOOP
void loop() {
  lerNextion();

  if (loraOK) {
  int packetSize = LoRa.parsePacket();
  if (packetSize) {
    String dados = "";
    while (LoRa.available()) {
      dados += (char)LoRa.read();
    }
    Serial.print("LoRa recebido: ");
    Serial.println(dados);

    lerNextion();
